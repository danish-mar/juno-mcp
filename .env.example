# --- Student account (own data) ---
# Legacy `email`/`password` still work and are treated as the student account.
STUDENT_EMAIL=student@example.com
STUDENT_PASSWORD=your_password

# --- Employee account (university-wide management) ---
# Required for the employee tools (search_university, get_student_* lookups)
# and for the authenticated profile-image proxy.
EMPLOYEE_EMAIL=employee@example.com
EMPLOYEE_PASSWORD=your_password

# --- Server ---
PORT=8987
# Public base URL the AI uses to reach this server (used to build profile-image
# proxy links). Set this to your externally reachable URL when not on localhost.
PUBLIC_URL=http://localhost:8987

# --- Proxy (optional) ---
# Use a proxy ONLY if one is configured below. Leave PROXY_URL empty and
# PROXY_USE_RANDOM=false to connect directly.
#
# Explicit proxy (http/https/socks4/socks5, optional inline auth):
PROXY_URL=
# Or auto-pick a working free proxy from ProxyScrape when no PROXY_URL is set:
PROXY_USE_RANDOM=false
PROXY_RANDOM_PROTOCOL=http
PROXY_RANDOM_COUNTRY=in
PROXY_RANDOM_TRIES=8
PROXY_TIMEOUT=15000
